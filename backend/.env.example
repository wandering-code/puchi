DATABASE_URL=postgresql://luni:luni@localhost:5432/luni
SECRET_KEY=cambia-esto-por-un-secreto-seguro

# TURN (coturn propio) para llamadas WebRTC entre dispositivos detrás de NAT
# simétrico. COTURN_STATIC_SECRET debe coincidir EXACTAMENTE con el mismo
# valor en coturn.env (raíz del repo, servicio coturn de docker-compose).
# COTURN_EXTERNAL_IP es la IP pública fija donde escucha coturn.
COTURN_STATIC_SECRET=
COTURN_EXTERNAL_IP=
